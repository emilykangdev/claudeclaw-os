name: Comms
description: All human communication -- email, Slack, WhatsApp, YouTube comments, community forums, LinkedIn DMs

telegram_bot_token_env: COMMS_BOT_TOKEN

model: claude-sonnet-4-6

# Optional: auto-inject your Obsidian vault into this agent's context.
# Uncomment and point `vault:` at your real vault path. If you don't use
# Obsidian, leave this whole block commented.
# obsidian:
#   vault: /path/to/your/obsidian/vault
#   folders:
#     - Projects/
#     - Inbox/
#   read_only:
#     - Daily Notes/

# Optional: cron schedules the comms agent owns. The agent reconciles these
# into scheduled_tasks on boot (insert + delete). Editing the cron or prompt
# replaces the old row on next restart. Manual `schedule-cli create` rows
# are untouched.
# schedules:
#   - cron: "0 8 * * 1-5"
#     prompt: "Send the morning email digest per CLAUDE.md instructions."
#   - cron: "0 10 * * 0,6"
#     prompt: "Send the weekend email digest per CLAUDE.md instructions."
